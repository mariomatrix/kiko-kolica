# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://kolica_user:SigurnaLozinka123!@127.0.0.1:5432/kolica_dev

# Session encryption key (use a long random secret in production)
KOLICA_SESSION_SECRET=kolica-local-session-secret-v1

# Allowed CORS origins separated by comma (e.g. http://localhost:8000,http://127.0.0.1:8000)
# Use * for development to allow all origins
KOLICA_CORS_ORIGINS=*

# Path to SQLite database used by migration script
SQLITE_DB_PATH=kolica.db

# GRM Paths
REQUEST_INBOX=/mnt/nas/004_Konstrukcija/010_BI_File_Drop/REQUEST
RESPONSE_ROOT=/mnt/nas/004_Konstrukcija/010_BI_File_Drop/ALDO_POC/responses
ERROR_ROOT=/mnt/nas/004_Konstrukcija/010_BI_File_Drop/ALDO_POC/errors
